{
  "name": "cifrashub",
  "version": "0.1.0",
  "description": "Chord sheet visualizer for any chordal instrument — guitar, bass, keyboard and more — with folders, transposition, metronome, setlists, and stage mode.",
  "license": "MIT",
  "author": "CifrasHub Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/Geeks-Zone/cifrashub.git"
  },
  "homepage": "https://www.cifrashub.com.br",
  "bugs": {
    "url": "https://github.com/Geeks-Zone/cifrashub/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/vercel-build.cjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:ci": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "generate-icons": "node scripts/generate-icons.cjs",
    "postinstall": "node scripts/patch-better-auth.cjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@neondatabase/neon-js": "^0.6.2-beta",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "esbuild": "0.28.1",
    "fastify": "5.8.5",
    "sharp": "0.35.3",
    "uuid": "14.0.0",
    "postcss": "8.5.10",
    "better-auth": "1.6.18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "postcss": "8.5.10",
    "shadcn": "^4.1.2",
    "sharp": "0.35.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "knip": {
    "entry": [
      "scripts/migrate.cjs",
      "scripts/merge-duplicate-favoritos.ts",
      "public/sw.js"
    ],
    "ignoreIssues": {
      "src/components/ui/**/*.tsx": [
        "exports",
        "types"
      ]
    }
  }
}
